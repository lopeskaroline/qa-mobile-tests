{
  "name": "mobile-automation-native-demo-app",
  "version": "1.0.0",
  "description": "Automacao mobile com WebdriverIO",
  "scripts": {
    "test:android": "wdio run wdio.android.conf.js",
    "test:ios": "wdio run wdio.ios.conf.js",
    "test:smoke": "wdio run wdio.conf.js --suite smoke",
    "allure:generate": "allure generate ./allure-results --clean -o ./allure-report",
    "allure:open": "allure open ./allure-report"
  },
  "devDependencies": {
    "@wdio/allure-reporter": "^9.0.0",
    "@wdio/browserstack-service": "^9.0.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "appium": "^2.0.0",
    "appium-uiautomator2-driver": "^4.2.9",
    "mocha": "^10.0.0"
  }
}
